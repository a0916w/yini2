# mercury-drama backend address (dev proxy target for /api)
VITE_API_PROXY=http://localhost:8000

# or call a deployed API directly (takes precedence over the proxy)
# VITE_API_BASE=https://your-api-host/api

# AES-256-CBC response-envelope key (64 hex chars), must match backend API_ENCRYPT_KEY
# VITE_API_ENCRYPT_KEY=
